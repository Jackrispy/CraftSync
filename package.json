{
  "name": "craftsync",
  "version": "1.0.0",
  "description": "Shared Minecraft world sync for friends",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "obfuscate": "javascript-obfuscator main.js --output main.obfuscated.js --compact true --string-array true --string-array-encoding base64 --identifier-names-generator hexadecimal --split-strings true --split-strings-chunk-length 10 --dead-code-injection false --self-defending false",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win dir --x64",
    "build:release": "npm run obfuscate && electron-builder --win --x64 --config.extraMetadata.main=main.obfuscated.js"
  },
  "build": {
    "appId": "com.craftsync.app",
    "productName": "CraftSync",
    "copyright": "Copyright 2026 CraftSync",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "dir",  "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CraftSync"
    },
    "files": [
      "main.obfuscated.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "assets/sqlite3.exe", "to": "sqlite3.exe" }
    ],
    "asar": true
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.0",
    "archiver": "^7.0.1",
    "axios": "^1.7.2",
    "node-stream-zip": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^4.1.1"
  }
}
